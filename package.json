{
  "name": "hex-index",
  "version": "0.6.0",
  "description": "hex-index - built on claude-base",
  "type": "module",
  "bin": {
    "claude-base-init": "./bin/init.ts"
  },
  "scripts": {
    "init": "tsx bin/init.ts",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:frontend": "vite --host",
    "build": "npm run build:api && npm run build:frontend",
    "build:api": "tsc -p tsconfig.api.json",
    "build:frontend": "vite build",
    "start": "node dist/api/index.js",
    "lint": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "eslint . --fix --max-warnings 0 --report-unused-disable-directives",
    "lint:sources": "node -e \"const fs=require('fs'); const files=[{f:'content/ingest-subscribed.json',k:'publications'},{f:'content/youtube-sources.json',k:'channels'}]; let ok=true; for(const {f,k} of files){const arr=JSON.parse(fs.readFileSync(f,'utf8'))[k]; const names=arr.map(x=>x.name); const sorted=[...names].sort((a,b)=>a.localeCompare(b,'en',{sensitivity:'base'})); for(let i=0;i<names.length;i++){if(names[i]!==sorted[i]){console.error(f+' is not sorted alphabetically by name: '+JSON.stringify(names[i])+' should come after '+JSON.stringify(sorted[i]));ok=false;break;}}} if(!ok)process.exit(1); console.log('Source files are sorted alphabetically.');\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "tsx tools/screenshots/capture.ts",
    "screenshot:compare": "tsx tools/screenshots/compare.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "discord:send": "tsx tools/discord/send.ts",
    "discord:read": "tsx tools/discord/read.ts",
    "gh:issue": "tsx tools/github/create-issue.ts",
    "gh:rate-limit": "tsx tools/github/check-rate-limit.ts",
    "feed:fetch": "tsx tools/feed/fetch.ts",
    "ingest": "tsx tools/ingest/run.ts",
    "discover": "tsx tools/discovery/analyze.ts",
    "cleanup:media": "tsx tools/cleanup-media-posts.ts",
    "wikipedia:retrofit": "tsx src/wikipedia/cli.ts retrofit",
    "wikipedia:stats": "tsx src/wikipedia/cli.ts stats",
    "wikipedia:enrich": "tsx src/wikipedia/cli.ts enrich",
    "job:ingest": "bash tools/cron/ingest.sh",
    "job:wiki-discover": "tsx tools/jobs/wikipedia-discover.ts",
    "job:wiki-rewrite": "tsx tools/jobs/wikipedia-rewrite.ts",
    "job:yt-ingest": "tsx tools/jobs/yt-ingest.ts",
    "job:article-rewrite": "tsx tools/jobs/article-rewrite.ts",
    "job:generate-images": "tsx tools/jobs/generate-images.ts",
    "job:tag-articles": "tsx tools/jobs/tag-articles.ts",
    "job:audit-html": "tsx tools/jobs/audit-html.ts",
    "job:commentary-audit": "tsx tools/jobs/commentary-audit.ts",
    "job:model-report": "tsx tools/jobs/model-report.ts",
    "job:quality-report": "tsx tools/jobs/quality-report.ts",
    "job:consolidate-weekly": "tsx tools/jobs/consolidate-weekly.ts",
    "job:send-weekly": "tsx tools/jobs/send-weekly.ts",
    "job:title-cleanup": "tsx tools/jobs/title-cleanup.ts",
    "job:build-weekly": "bash tools/cron/build-weekly.sh",
    "job:friday-publish": "bash tools/cron/friday-publish.sh",
    "claude:start": "bash tools/claude-loop/start-session.sh",
    "claude:attach": "tmux attach -t claude-editor",
    "claude:check-prs": "bash tools/claude-loop/check-prs.sh",
    "sync:library": "tsx tools/sync-library.ts",
    "static:generate": "tsx tools/static-site/generate.ts",
    "static:clean": "tsx tools/static-site/generate.ts --clean",
    "static:preview": "npx serve docs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/archiver": "^7.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/turndown": "^5.0.6",
    "archiver": "^7.0.1",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.0",
    "turndown": "^7.2.2",
    "twilio": "^5.13.0",
    "yaml": "^2.8.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.6",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.5",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
